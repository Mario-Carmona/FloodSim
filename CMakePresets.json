  "packagePresets": [
    {
      "name": "common-package-options",
      "hidden": true,
      "variables": {
        "CPACK_PACKAGE_DIRECTORY": "${sourceDir}/installer"
      }
    },
    {
      "name": "cli-only",
      "hidden": true,
      "inherits": [ "common-package-options" ],
