{
  "version": 9,
  "cmakeMinimumRequired": {
    "major": 4,
    "minor": 1,
    "patch": 1
  },
  "configurePresets": [
    {
      "name": "common-configure-options",
      "hidden": true,
      "description": "Base preset defining common cache variables shared by all presets.",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "environment": {
        "HOST_BUILD_DIR": "${sourceDir}/build/${hostSystemName}"
      }
    },
    {
      "name": "app",
      "hidden": true,
      "inherits": [
        "common-configure-options"
      ],
      "description": "Defines settings for building project executables.",
      "cacheVariables": {
        "BUILD_APP": "ON",
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "CMAKE_CXX_EXTENSIONS": "OFF",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_RUNTIME_OUTPUT_DIRECTORY": "${sourceDir}/bin/${hostSystemName}/$<CONFIG>",
        "CMAKE_LIBRARY_OUTPUT_DIRECTORY": "${sourceDir}/lib/${hostSystemName}/$<CONFIG>",
        "CMAKE_ARCHIVE_OUTPUT_DIRECTORY": "${sourceDir}/lib/${hostSystemName}/$<CONFIG>",
        "X_VCPKG_APPLOCAL_DEPS_INSTALL": "ON",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/external/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_INSTALL_OPTIONS": "--clean-after-build",
        "VCPKG_INSTALLED_DIR": "$env{HOST_BUILD_DIR}/vcpkg_installed"
      },
      "environment": {
        "VCPKG_DEFAULT_BINARY_CACHE": "$env{HOST_BUILD_DIR}/vcpkg_cache"
      }
    },
    {
      "name": "debug",
      "hidden": true,
      "inherits": [
        "common-configure-options"
      ],
      "description": "",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "hidden": true,
      "inherits": [
        "common-configure-options"
      ],
      "description": "",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "rel-with-deb-info",
      "hidden": true,
      "inherits": [
        "common-configure-options"
      ],
      "description": "",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "cli",
      "hidden": true,
      "inherits": [
        "common-configure-options"
      ],
      "description": "",
      "cacheVariables": {
        "ENABLE_GUI": "OFF"
      }
    },
    {
      "name": "gui",
      "hidden": true,
      "inherits": [
        "common-configure-options"
      ],
      "description": "",
      "cacheVariables": {
        "ENABLE_GUI": "ON"
      }
    },
    {
      "name": "windows",
      "hidden": true,
      "inherits": [
        "common-configure-options"
      ],
      "description": "Windows-specific preset using Visual Studio 2026 and static vcpkg triplets.",
      "architecture": "x64",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "generator": "Visual Studio 18 2026",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "VCPKG_HOST_TRIPLET": "x64-windows"
      }
    },
    {
      "name": "linux",
      "hidden": true,
      "inherits": [
        "common-configure-options"
      ],
      "description": "Linux-specific preset using Ninja and static vcpkg triplets.",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "generator": "Ninja",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-linux",
        "VCPKG_HOST_TRIPLET": "x64-linux",
        "CMAKE_CXX_COMPILER": "/usr/bin/g++-12",
        "CMAKE_MAKE_PROGRAM": "/usr/bin/ninja"
      },
      "environment": {
        "CC": "/usr/bin/gcc-12",
        "CXX": "/usr/bin/g++-12"
      }
    },
    {
      "name": "windows-cli-only-debug",
      "inherits": [
        "windows",
        "app",
        "cli",
        "debug"
      ],
      "description": ""
    },
    {
      "name": "windows-cli-only-release",
      "inherits": [
        "windows",
        "app",
        "cli",
        "release"
      ],
      "description": ""
    },
    {
      "name": "windows-cli-only-rel-with-deb-info",
      "inherits": [
        "windows",
        "app",
        "cli",
        "rel-with-deb-info"
      ],
      "description": ""
    },
    {
      "name": "windows-full-suite-debug",
      "inherits": [
        "windows",
        "app",
        "gui",
        "debug"
      ],
      "description": ""
    },
    {
      "name": "windows-full-suite-release",
      "inherits": [
        "windows",
        "app",
        "gui",
        "release"
      ],
      "description": ""
    },
    {
      "name": "windows-full-suite-rel-with-deb-info",
      "inherits": [
        "windows",
        "app",
        "gui",
        "rel-with-deb-info"
      ],
      "description": ""
    },
    {
      "name": "linux-cli-only-debug",
      "inherits": [ "linux", "app", "cli", "debug" ],
      "description": "Debug build for Linux CLI"
    },
    {
      "name": "linux-cli-only-release",
      "inherits": [ "linux", "app", "cli", "release" ],
      "description": "Release build for Linux CLI"
    },
    {
      "name": "linux-full-suite-debug",
      "inherits": [ "linux", "app", "gui", "debug" ],
      "description": "Debug build for Linux GUI"
    },
    {
      "name": "linux-full-suite-release",
      "inherits": [ "linux", "app", "gui", "release" ],
      "description": "Release build for Linux GUI"
    },
    {
      "name": "tests",
      "hidden": true,
      "inherits": [ "common-configure-options", "cli", "debug" ],
      "description": "",
      "cacheVariables": {
        "BUILD_TESTS": "ON"
      }
    },
    {
      "name": "windows-tests-all",
      "inherits": [ "windows", "tests" ],
      "description": "",
      "cacheVariables": {
        "BUILD_ALL_TESTS": "ON"
      }
    },
    {
      "name": "windows-tests-state-updater",
      "inherits": [ "windows", "tests" ],
      "description": "",
      "cacheVariables": {
        "ENABLE_STATE_UPDATER_ADAPTERS": "ON"
      }
    },
    {
      "name": "python-envs",
      "hidden": true,
      "inherits": [
        "common-configure-options"
      ],
      "description": "",
      "cacheVariables": {
        "BUILD_PYTHON_ENVS": "ON"
      }
    },
    {
      "name": "python-data",
      "inherits": [
        "python-envs"
      ],
      "description": "",
      "cacheVariables": {
        "PYTHON_SUBDIR_NAME": "data_pipeline",
        "ISOLATE_ENVIRONMENT": "OFF"
      }
    },
    {
      "name": "python-models",
      "inherits": [
        "python-envs"
      ],
      "description": "",
      "cacheVariables": {
        "PYTHON_SUBDIR_NAME": "models",
        "ISOLATE_ENVIRONMENT": "ON"
      }
    },
    {
      "name": "python-visualizer",
      "inherits": [
        "python-envs"
      ],
      "description": "",
      "cacheVariables": {
        "PYTHON_SUBDIR_NAME": "visualizer",
        "ISOLATE_ENVIRONMENT": "OFF"
      }
    }
  ],
  "buildPresets": [
