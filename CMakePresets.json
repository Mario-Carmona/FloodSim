{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 25,
        "patch": 0
    },
    "configurePresets": 
    [
        {
            "name": "common",
            "hidden": true,
            "description": "Base preset defining common cache variables shared by all presets.",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_CXX_STANDARD": "17",
                "CMAKE_CXX_STANDARD_REQUIRED": "ON",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "apps",
            "hidden": true,
            "inherits": ["common"],
            "description": "Defines settings for building project executables.",
            "architecture": "x64",
            "cacheVariables": {
                "DANASIM_BUILD_APPS": "ON",
                "DANASIM_BUILD_DOCS": "OFF",
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/external/vcpkg/scripts/buildsystems/vcpkg.cmake",
                "VCPKG_INSTALLED_DIR": "${sourceDir}/vcpkg_installed"
            }
        },
        {
            "name": "windows-apps",
            "inherits": ["apps"],
            "description": "Windows-specific preset using Visual Studio 2022 and static vcpkg triplets.",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "generator": "Visual Studio 17 2022",
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x64-windows-static",
                "VCPKG_HOST_TRIPLET": "x64-windows-static"
            }
        },
        {
            "name": "docs",
            "inherits": ["common"],
            "description": "",
            "cacheVariables": {
                "DANASIM_BUILD_APPS": "OFF",
                "DANASIM_BUILD_DOCS": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "windows-apps-debug",
            "configurePreset": "windows-apps",
            "description": "Build the Windows Debug configuration.",
            "configuration": "Debug"
        },
        {
            "name": "windows-apps-release",
            "configurePreset": "windows-apps",
            "description": "Build the Windows Release configuration.",
            "configuration": "Release"
        }
    ],
    "workflowPresets": [
        {
            "name": "windows-apps-debug",
            "description": "Workflow to configure and build the Windows Debug target.",
            "steps": [
                { "type": "configure", "name": "windows-apps" },
                { "type": "build", "name": "windows-apps-debug" }
            ]
        },
        {
            "name": "windows-apps-release",
            "description": "Workflow to configure and build the Windows Release target.",
            "steps": [
                { "type": "configure", "name": "windows-apps" },
                { "type": "build", "name": "windows-apps-release" }
            ]
        }
    ]
}