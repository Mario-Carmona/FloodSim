        "CPACK_COMPONENTS_ALL": "CLI"
      }
    },
    {
      "name": "full-suite",
      "hidden": true,
      "inherits": [ "common-package-options" ],
      "variables": {
        "CPACK_COMPONENTS_ALL": "CLI;GUI"
      }
    },
    {
      "name": "windows-cli-only",
      "displayName": "Installer - CLI Only",
      "inherits": [ "cli-only" ],
      "configurePreset": "windows-cli-only-release"
    },
    {
      "name": "windows-full-suite",
      "displayName": "Installer - GUI & CLI",
      "inherits": [ "full-suite" ],
      "configurePreset": "windows-full-suite-release"
    },
    {
      "name": "linux-cli-only",
      "displayName": "Installer - CLI Only",
      "inherits": [ "cli-only" ],
      "configurePreset": "linux-cli-only-release"
    },
    {
      "name": "linux-full-suite",
      "displayName": "Installer - GUI & CLI",
      "inherits": [ "full-suite" ],
      "configurePreset": "linux-full-suite-release"
    }
  ],
