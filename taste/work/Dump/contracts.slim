-- ------
-- SYNTAX
-- ------
-- system <SLIM FUNCTION NAME>
-- properties
--   Contracts => (
--     [
--       Name => "<NAME>";
--       Assumption => "<ASSUMPTION>";
--       Guarantee => "<GUARANTEE>";
--     ],
--     ...
--   );
-- end <SLIM FUNCTION NAME>;
-- -------
-- EXAMPLE
-- -------
-- system Battery
-- properties
--   Contracts => (
--     [
--       Name => "power";
--       Assumption => "always(get_voltage >= 10)";
--       Guarantee => "always(voltage_out >= 10)";
--     ]
--   );
-- end Battery;
