-- ------
-- SYNTAX
-- ------
-- system implementation <SLIM FUNCTION NAME>.others
-- properties
--   FaultInjections => (
--     [
--       Description => "<DESCRIPTION>";
--       Fault_Model => <FAULT MODEL>;
--       Fault_Dynamics => <(PERMANENT|TRANSIENT)>;
--       Probability => <PROBABILITY>;
--       Input => <RI/PI PARAMETER NAME>;
--       Varout => <RI/PI PARAMETER NAME>;
--       ParameterList => ([Name=>Term; Value=>"<VALUE>"]);
--     ],
--     ...
--   );
-- end <SLIM FUNCTION NAME>.others;
