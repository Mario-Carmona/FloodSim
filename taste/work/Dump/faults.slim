-- EXAMPLE
-- -------
-- system implementation Generator.others
-- properties
--   FaultInjections => (
--     [
--       Description => "Dead";
--       Fault_Model => StuckAt;
--       Fault_Dynamics => Permanent;
--       Probability => 1.e-7;
--       Input => voltage_out.voltage;
--       Varout => voltage_out.voltage;
--       ParameterList => ([Name=>Term; Value=>"0"]);
--     ]
--   );
-- end Generator.others;
